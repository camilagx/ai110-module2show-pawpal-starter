classDiagram
    %% Matches final pawpal_system.py. Scheduler still merges tasks across ALL
    %% of an owner's pets into one DailyPlan (not one plan per pet).
    %% New since the initial diagram: Task now holds a back-reference to its
    %% Pet (set automatically by Pet.add_task) plus recurrence state
    %% (recurs_on, due_date), so mark_complete() can generate and enqueue the
    %% next occurrence itself via next_occurrence(). Scheduler also gained
    %% filter_tasks(), tasks_at_time(), and conflict_warnings().

    class Frequency {
        <<enumeration>>
        ONCE
        DAILY
        WEEKLY
    }

    class Task {
        +str id
        +str description
        +str time
        +Frequency frequency
        +bool completed
        +list[int] recurs_on
        +date due_date
        +Pet pet
        +mark_complete() Task
        +mark_incomplete() None
        +next_occurrence() Task
        +is_due(on_date) bool
        +__repr__() str
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +Owner owner
        +list[Task] tasks
        +add_task(task) None
        +remove_task(task_id) None
        +get_tasks() list[Task]
        +__repr__() str
    }

    class Owner {
        +str name
        +dict preferences
        +list[Pet] pets
        +add_pet(pet) None
        +get_pets() list[Pet]
        +get_all_tasks() list[tuple]
        +__repr__() str
    }

    class ScheduledTask {
        +Pet pet
        +Task task
        +str reason
        +__repr__() str
    }

    class DailyPlan {
        +Owner owner
        +str date
        +list[ScheduledTask] scheduled_tasks
        +list[list[ScheduledTask]] conflicts
        +add_scheduled_task(scheduled_task) None
        +summary() str
    }

    class Scheduler {
        +build_schedule(owner, date) DailyPlan
        +get_due_tasks(owner, on_date) list[tuple]
        +filter_tasks(pet_tasks, pet_name, completed) list[tuple]
        +sort_by_time(pet_tasks) list[tuple]
        +find_conflicts(scheduled_tasks) list[list[ScheduledTask]]
        +tasks_at_time(pet_tasks, time) list[tuple]
        +conflict_warnings(scheduled_tasks) list[str]
        +explain(task) str
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Task "many" --> "1" Pet : belongs to (back-ref)
    Task --> Frequency
    Task ..> Task : next_occurrence() creates
    Owner "1" --> "many" DailyPlan : requests
    DailyPlan "1" --> "many" ScheduledTask : contains
    ScheduledTask --> Pet : for
    ScheduledTask --> Task : wraps
    Scheduler ..> DailyPlan : creates
    Scheduler ..> ScheduledTask : creates
